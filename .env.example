# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — used by the analysis/scoring pipeline
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated list of emails allowed into /admin
ADMIN_EMAILS=you@example.com

# Public base URL (used for sitemap / canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
